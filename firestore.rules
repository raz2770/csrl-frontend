// ============================================================
// Firestore Security Rules for CSRL App
// Paste this into:
//   Firebase Console → Firestore → Rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return request.auth != null && userDoc().role == 'admin';
    }

    function isCentre(centreCode) {
      return request.auth != null
        && userDoc().role == 'centre'
        && userDoc().centreCode == centreCode;
    }

    function isStudent(rollKey) {
      return request.auth != null
        && userDoc().role == 'student'
        && userDoc().rollKey == rollKey;
    }

    function isStudentOfCentre(centreCode) {
      return request.auth != null
        && userDoc().role == 'student'
        && userDoc().centreCode == centreCode;
    }

    // ── users/ ─────────────────────────────────────────────────
    // Each user can only read their own profile
    // Only admin (via Admin SDK / server) can write
    match /users/{uid} {
      allow read:  if request.auth.uid == uid;
      allow write: if false; // Admin SDK only
    }

    // ── centres/ ───────────────────────────────────────────────
    match /centres/{centreCode} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── students/ ──────────────────────────────────────────────
    match /students/{rollKey} {
      // Admin: full access
      allow read, write: if isAdmin();
      // Centre: read only their own students
      allow read: if isCentre(resource.data.centerCode)
                  || isStudentOfCentre(resource.data.centerCode);
      // Student: read own record only
      allow read: if isStudent(rollKey);
    }

    // ── testScores/ ────────────────────────────────────────────
    match /testScores/{rollKey} {
      // Admin: full access
      allow read, write: if isAdmin();
      // Centre: read scores of their own students
      allow read: if request.auth != null
                  && (userDoc().role == 'centre' || userDoc().role == 'student');
      // Student: read own scores only
      allow read: if isStudent(rollKey);
    }
  }
}
